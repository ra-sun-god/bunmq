{
  "name": "bunmq",
  "version": "1.0.0",
  "description": "Advanced message queue for Bun — SQLite, PostgreSQL, MySQL/MariaDB, and in-memory, all via Bun's built-in SQL client",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapters/bun-sql":  "./src/adapters/bun-sql.ts",
    "./adapters/memory":   "./src/adapters/memory.ts",
    "./adapters/schema":   "./src/adapters/schema.ts"
  },
  "scripts": {
    "test": "bun test --timeout 15000",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm"
  },
  "keywords": [
    "bun", "sqlite", "postgresql", "mysql", "mariadb",
    "message-queue", "mq", "queue", "worker", "job"
  ],
  "license": "MIT",
  "devDependencies": {
    "bun-types": "latest"
  }
}
