{
  "name": "@rasungod/bunmq",
  "version": "0.0.6",
  "description": "Advanced message queue for Bun — SQLite, PostgreSQL, MySQL, MariaDB, Redis, and in-memory via Bun's built-in clients",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/types.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapters/bun-sql": "./src/adapters/bun-sql.ts",
    "./adapters/memory": "./src/adapters/memory.ts",
    "./adapters/redis": "./src/adapters/redis.ts",
    "./adapters/schema": "./src/adapters/schema.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm",
    "test": "bun test --timeout 15000",
    "dev": "bun run ./src/index.ts"
  },
  "keywords": [
    "bun",
    "sqlite",
    "postgresql",
    "mysql",
    "mariadb",
    "redis",
    "message-queue",
    "mq",
    "queue",
    "worker",
    "job",
    "bunmq",
    "bun-sql",
    "task-queue",
    "background-jobs"
  ],
  "license": "MIT",
  "author": {
    "name": "Razak"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ra-sun-god/bunmq.git"
  },
  "bugs": {
    "url": "https://github.com/ra-sun-god/bunmq/issues",
    "email": "hello@maxxpainn.com"
  },
  "homepage": "https://www.npmjs.com/package/@rasungod/bunmq",
  "devDependencies": {
    "bun-types": "latest"
  }
}
